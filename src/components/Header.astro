---
import { useTranslations } from '../i18n/utils';

const locale = Astro.currentLocale ?? 'en';
const t = useTranslations(locale);
const currentPath = Astro.url.pathname;

// Build the same page URL in the other language
const otherLocale = locale === 'en' ? 'pt-br' : 'en';
const otherLocalePath = (() => {
  if (locale === 'en') {
    return `/pt-br${currentPath === '/' ? '' : currentPath}`;
  } else {
    const stripped = currentPath.replace(/^\/pt-br/, '') || '/';
    return stripped;
  }
})();

const navItems = [
  { href: locale === 'en' ? '/' : '/pt-br', label: t('nav.about') },
  { href: locale === 'en' ? '/publications' : '/pt-br/publications', label: t('nav.publications') },
  { href: locale === 'en' ? '/teaching' : '/pt-br/teaching', label: t('nav.teaching') },
  { href: locale === 'en' ? '/materials' : '/pt-br/materials', label: t('nav.materials') },
  { href: locale === 'en' ? '/cv' : '/pt-br/cv', label: t('nav.cv') },
];

const isActive = (href: string) => {
  if (href === '/' || href === '/pt-br') {
    return currentPath === '/' || currentPath === '/pt-br' || currentPath === '/pt-br/';
  }
  return currentPath === href || currentPath.startsWith(href + '/');
};
---

<header class="sticky top-0 z-50 bg-surface/90 dark:bg-surface-dark/90 backdrop-blur-md border-b border-border dark:border-border-dark">
  <nav class="max-w-content mx-auto px-6 sm:px-8 lg:px-32 xl:px-48 2xl:px-64 py-4">
    <div class="flex items-center justify-between">
      <a href={locale === 'en' ? '/' : '/pt-br'} class="font-serif text-lg text-ink dark:text-ink-dark hover:text-accent dark:hover:text-accent-dark transition-colors">
        Felipe Lamarca
      </a>

      <div class="flex items-center gap-5">
        <ul class="hidden md:flex items-center gap-6 text-sm">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'tracking-wide transition-colors',
                  isActive(item.href)
                    ? 'text-accent dark:text-accent-dark'
                    : 'text-ink-secondary dark:text-ink-secondary-dark hover:text-ink dark:hover:text-ink-dark'
                ]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Language switcher -->
        <a
          href={otherLocalePath}
          class="text-xs tracking-widest font-medium text-ink-muted dark:text-ink-muted-dark hover:text-ink dark:hover:text-ink-dark transition-colors"
          title={otherLocale === 'en' ? 'Switch to English' : 'Mudar para Português'}
        >
          {locale === 'en' ? 'PT' : 'EN'}
        </a>

        <button
          id="theme-toggle"
          class="p-1.5 rounded text-ink-muted dark:text-ink-muted-dark hover:text-ink dark:hover:text-ink-dark transition-colors"
          aria-label="Toggle theme"
        >
          <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <svg class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </button>

        <button
          id="mobile-menu-toggle"
          class="md:hidden p-1.5 rounded text-ink-muted dark:text-ink-muted-dark hover:text-ink dark:hover:text-ink-dark transition-colors"
          aria-label="Toggle menu"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <ul id="mobile-menu" class="hidden md:hidden mt-4 pb-2 space-y-1 text-sm">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'block py-2 tracking-wide transition-colors',
              isActive(item.href)
                ? 'text-accent dark:text-accent-dark'
                : 'text-ink-secondary dark:text-ink-secondary-dark'
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li class="pt-2 border-t border-border dark:border-border-dark">
        <a href={otherLocalePath} class="block py-2 text-xs tracking-widest font-medium text-ink-muted dark:text-ink-muted-dark">
          {locale === 'en' ? 'Português (PT-BR)' : 'English (EN)'}
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const themeToggle = document.getElementById('theme-toggle');
  const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  themeToggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  mobileMenuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
