---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CV" description="Curriculum vitae – Felipe Lamarca">
  <div class="space-y-12">
    <header>
      <h1 class="font-serif text-3xl font-medium text-ink dark:text-ink-dark mb-2">CV</h1>
      <p class="text-ink-secondary dark:text-ink-secondary-dark">Education, scholarships, distinctions, and references</p>
      <div class="mt-4">
        <a
          href="https://drive.google.com/file/d/1dFBrI109flg6zSQHnFIxUd1DRfieCYAT/view?usp=sharing"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 text-sm border border-border dark:border-border-dark rounded-sm text-ink-secondary dark:text-ink-secondary-dark hover:border-accent dark:hover:border-accent-dark hover:text-accent dark:hover:text-accent-dark transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Download PDF
        </a>
      </div>
    </header>

    <section>
      <h2 class="section-title">Education</h2>
      <div class="divide-y divide-border dark:divide-border-dark">
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3">
          <span class="text-sm font-medium text-ink-muted dark:text-ink-muted-dark shrink-0 sm:w-28">2024–present</span>
          <div>
            <p class="text-ink dark:text-ink-dark font-medium">M.Sc. in Political Science</p>
            <p class="text-ink-secondary dark:text-ink-secondary-dark text-sm"><a href="https://iesp.uerj.br/en/" class="link" target="_blank" rel="noopener noreferrer">Institute of Social and Political Studies</a> (IESP-UERJ)</p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3">
          <span class="text-sm font-medium text-ink-muted dark:text-ink-muted-dark shrink-0 sm:w-28">2021–2024</span>
          <div>
            <p class="text-ink dark:text-ink-dark font-medium">B.A. in Data Science and Artificial Intelligence</p>
            <p class="text-ink-secondary dark:text-ink-secondary-dark text-sm"><a href="https://emap.fgv.br/en" class="link" target="_blank" rel="noopener noreferrer">School of Applied Mathematics</a> (FGV EMAp)</p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3">
          <span class="text-sm font-medium text-ink-muted dark:text-ink-muted-dark shrink-0 sm:w-28">2019–2024</span>
          <div>
            <p class="text-ink dark:text-ink-dark font-medium">B.A. in Social Sciences</p>
            <p class="text-ink-secondary dark:text-ink-secondary-dark text-sm"><a href="https://cpdoc.fgv.br/en" class="link" target="_blank" rel="noopener noreferrer">School of Social Sciences</a> (FGV CPDOC)</p>
          </div>
        </div>
      </div>
    </section>

    <section>
      <h2 class="section-title">Scholarships</h2>
      <div class="divide-y divide-border dark:divide-border-dark">
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3">
          <span class="text-sm font-medium text-ink-muted dark:text-ink-muted-dark shrink-0 sm:w-28">2026–2027</span>
          <p class="text-ink-secondary dark:text-ink-secondary-dark">Graduate Scholarship — FAPERJ Nota 10 (Fundação de Amparo à Pesquisa do Estado do Rio de Janeiro).</p>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3">
          <span class="text-sm font-medium text-ink-muted dark:text-ink-muted-dark shrink-0 sm:w-28">2025–2026</span>
          <p class="text-ink-secondary dark:text-ink-secondary-dark">Graduate Scholarship — CAPES (Coordenação de Aperfeiçoamento de Pessoal de Nível Superior).</p>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3">
          <span class="text-sm font-medium text-ink-muted dark:text-ink-muted-dark shrink-0 sm:w-28">2021–2022</span>
          <p class="text-ink-secondary dark:text-ink-secondary-dark">Institutional Scientific Initiation Scholarship — CNPq.</p>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3">
          <span class="text-sm font-medium text-ink-muted dark:text-ink-muted-dark shrink-0 sm:w-28">2019–2021</span>
          <p class="text-ink-secondary dark:text-ink-secondary-dark">Institutional Scientific Initiation Scholarship — FGV.</p>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3">
          <span class="text-sm font-medium text-ink-muted dark:text-ink-muted-dark shrink-0 sm:w-28">2019–2024</span>
          <p class="text-ink-secondary dark:text-ink-secondary-dark">90% Merit Scholarship for undergraduate studies at FGV, awarded for outstanding performance in the entrance examination.</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="section-title">Distinctions</h2>
      <div class="divide-y divide-border dark:divide-border-dark">
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3">
          <span class="text-sm font-medium text-ink-muted dark:text-ink-muted-dark shrink-0 sm:w-28">2026</span>
          <p class="text-ink-secondary dark:text-ink-secondary-dark">2nd Runner Up, Best DH Tool or Suite of Tools – <a href="http://dhawards.org/dhawards2025/results/" class="link" target="_blank" rel="noopener noreferrer">DH Awards 2025</a>, for <a href="https://github.com/felipelmc/RelicarIA" class="link" target="_blank" rel="noopener noreferrer">RelicarIA</a> (joint work with Danielle Sanches de Almeida).</p>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3">
          <span class="text-sm font-medium text-ink-muted dark:text-ink-muted-dark shrink-0 sm:w-28">2026</span>
          <p class="text-ink-secondary dark:text-ink-secondary-dark">Selected to receive the FAPERJ Nota 10 Graduate Scholarship for outstanding performance in the first year of the Master's program in Political Science at IESP-UERJ.</p>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3">
          <span class="text-sm font-medium text-ink-muted dark:text-ink-muted-dark shrink-0 sm:w-28">2025</span>
          <p class="text-ink-secondary dark:text-ink-secondary-dark">Professor Carlos Eduardo Sarmento Academic Distinction Award, School of Social Sciences (FGV CPDOC), for achieving the highest academic performance among the Class of 2025 undergraduate students.</p>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3">
          <span class="text-sm font-medium text-ink-muted dark:text-ink-muted-dark shrink-0 sm:w-28">2024</span>
          <p class="text-ink-secondary dark:text-ink-secondary-dark">1st place admission to the Master's program in Political Science at IESP-UERJ.</p>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3">
          <span class="text-sm font-medium text-ink-muted dark:text-ink-muted-dark shrink-0 sm:w-28">2020</span>
          <p class="text-ink-secondary dark:text-ink-secondary-dark">Best Paper Award, History and Social Sciences Students' Week (FGV CPDOC).</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="section-title">Conferences & Training</h2>
      <p class="text-sm text-ink-muted dark:text-ink-muted-dark mb-4">Conferences attended as participant and training activities. For presentations, see <a href="/publications" class="link">Publications</a>.</p>
      <div class="space-y-2">
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3 border-b border-border dark:border-border-dark">
          <span class="text-sm font-medium text-ink-muted dark:text-ink-muted-dark shrink-0">February 2026</span>
          <p class="text-ink-secondary dark:text-ink-secondary-dark">
            <a href="https://www.effectivealtruism.org/ea-global" class="link" target="_blank" rel="noopener noreferrer">Effective Altruism Global</a> – San Francisco, CA, United States (full funding).
          </p>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3 border-b border-border dark:border-border-dark">
          <span class="text-sm font-medium text-ink-muted dark:text-ink-muted-dark shrink-0">November 2025</span>
          <p class="text-ink-secondary dark:text-ink-secondary-dark">
            Academic writing and publication of quantitative papers in Social Sciences @ IESP-UERJ.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3 border-b border-border dark:border-border-dark">
          <span class="text-sm font-medium text-ink-muted dark:text-ink-muted-dark shrink-0">July 2025</span>
          <p class="text-ink-secondary dark:text-ink-secondary-dark">
            Advanced Text-As-Data: Word Embeddings, Deep Learning, and LLMs @ IESP-UERJ.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3 border-b border-border dark:border-border-dark">
          <span class="text-sm font-medium text-ink-muted dark:text-ink-muted-dark shrink-0">July 2024</span>
          <p class="text-ink-secondary dark:text-ink-secondary-dark">
            <a href="https://sicss.io/2024/fgv-ecmi-brazil/" class="link" target="_blank" rel="noopener noreferrer">SICSS: Summer Institute in Computational Social Science</a> – Rio de Janeiro, RJ, Brazil.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3 border-b border-border dark:border-border-dark">
          <span class="text-sm font-medium text-ink-muted dark:text-ink-muted-dark shrink-0">July 2024</span>
          <p class="text-ink-secondary dark:text-ink-secondary-dark">
            <a href="https://www.ml4good.org/" class="link" target="_blank" rel="noopener noreferrer">ML4Good Bootcamp</a>.
          </p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="section-title">References</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border dark:border-border-dark">
              <th class="text-left py-3 px-4 font-medium text-ink dark:text-ink-dark">Name</th>
              <th class="text-left py-3 px-4 font-medium text-ink dark:text-ink-dark">Institution</th>
              <th class="text-left py-3 px-4 font-medium text-ink dark:text-ink-dark">What for</th>
              <th class="text-left py-3 px-4 font-medium text-ink dark:text-ink-dark">Email</th>
            </tr>
