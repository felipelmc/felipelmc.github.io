---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Learning" description="Selected repositories and workshops from my studies">
  <div class="space-y-12">
    <header>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Learning</h1>
      <p class="text-gray-600 dark:text-gray-400">Selected repositories and workshops from my studies</p>
    </header>

    <section>
      <h2 class="section-title">Repositories</h2>

      <div class="space-y-6">
        <div class="card">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
            <h3 class="font-semibold text-gray-900 dark:text-white">Machine Learning</h3>
            <span class="text-sm text-gray-500 dark:text-gray-400">FGV EMAp, 2024.1, Undergraduate</span>
          </div>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
            Probabilistic machine learning, mixture models, and approximate Bayesian inference.
          </p>
          <div class="mt-3 text-sm">
            <a href="https://github.com/felipelmc/Machine-Learning" class="link" target="_blank" rel="noopener noreferrer">GitHub →</a>
          </div>
        </div>

        <div class="card">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
            <h3 class="font-semibold text-gray-900 dark:text-white">Deep Learning</h3>
            <span class="text-sm text-gray-500 dark:text-gray-400">FGV EMAp, 2024.2, Undergraduate</span>
          </div>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
            Foundations of NN, CNNs, LSTMs, GANs, Transformers, transfer learning, and autoencoders.
          </p>
          <div class="mt-3 text-sm">
            <a href="https://github.com/felipelmc/Deep-Learning" class="link" target="_blank" rel="noopener noreferrer">GitHub →</a>
          </div>
        </div>

        <div class="card">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
            <h3 class="font-semibold text-gray-900 dark:text-white">Lego I</h3>
            <span class="text-sm text-gray-500 dark:text-gray-400">IESP-UERJ, 2025.1, Graduate</span>
          </div>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
            Quantitative social science: data analysis, research design, probability, inference.
          </p>
          <div class="mt-3 flex gap-4 text-sm">
            <a href="https://github.com/felipelmc/Lego-I" class="link" target="_blank" rel="noopener noreferrer">GitHub →</a>
            <a href="https://felipelamarca.com/Lego-I/" class="link" target="_blank" rel="noopener noreferrer">Website →</a>
          </div>
        </div>

        <div class="card">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
            <h3 class="font-semibold text-gray-900 dark:text-white">Lego II</h3>
            <span class="text-sm text-gray-500 dark:text-gray-400">IESP-UERJ, 2025.2, Graduate</span>
          </div>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
            Linear regression models and extensions.
          </p>
          <div class="mt-3 flex gap-4 text-sm">
            <a href="https://github.com/felipelmc/Lego-II" class="link" target="_blank" rel="noopener noreferrer">GitHub →</a>
            <a href="https://felipelamarca.com/Lego-II/" class="link" target="_blank" rel="noopener noreferrer">Website →</a>
          </div>
        </div>
      </div>
    </section>

    <section>
      <h2 class="section-title">Workshops, Training & Events</h2>

      <div class="space-y-4">
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3 border-b border-gray-100 dark:border-gray-800">
          <span class="text-sm font-medium text-gray-500 dark:text-gray-400 shrink-0">February 2026</span>
          <p class="text-gray-700 dark:text-gray-300">
            <a href="https://www.effectivealtruism.org/ea-global" class="link" target="_blank" rel="noopener noreferrer">Effective Altruism Global</a> — San Francisco, CA (full funding).
          </p>
        </div>

        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3 border-b border-gray-100 dark:border-gray-800">
          <span class="text-sm font-medium text-gray-500 dark:text-gray-400 shrink-0">November 2025</span>
          <p class="text-gray-700 dark:text-gray-300">
            Academic writing and publication of quantitative papers in Social Sciences @ IESP-UERJ.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3 border-b border-gray-100 dark:border-gray-800">
          <span class="text-sm font-medium text-gray-500 dark:text-gray-400 shrink-0">July 2025</span>
          <p class="text-gray-700 dark:text-gray-300">
            Advanced Text-As-Data: Word Embeddings, Deep Learning, and LLMs @ IESP-UERJ.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3 border-b border-gray-100 dark:border-gray-800">
          <span class="text-sm font-medium text-gray-500 dark:text-gray-400 shrink-0">July 2024</span>
          <p class="text-gray-700 dark:text-gray-300">
            <a href="https://sicss.io/2024/fgv-ecmi-brazil/" class="link" target="_blank" rel="noopener noreferrer">SICSS: Summer Institute in Computational Social Science</a>
          </p>
        </div>

        <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 py-3 border-b border-gray-100 dark:border-gray-800">
          <span class="text-sm font-medium text-gray-500 dark:text-gray-400 shrink-0">July 2024</span>
          <p class="text-gray-700 dark:text-gray-300">
            <a href="https://www.ml4good.org/" class="link" target="_blank" rel="noopener noreferrer">ML4Good Bootcamp</a>
          </p>
        </div>
      </div>
    </section>
  </div>
</Layout>
