---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Teaching" description="Courses I've taught or assisted in, across social science and data science">
  <div class="space-y-12">
    <header>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">Teaching</h1>
      <p class="text-gray-600 dark:text-gray-400">Courses I've taught or assisted in, across social science and data science</p>
    </header>

    <section>
      <h2 class="section-title">Short Courses</h2>

      <div class="space-y-6">
        <div class="card">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
            <h3 class="font-semibold text-gray-900 dark:text-white">Machine Learning</h3>
            <span class="text-sm text-gray-500 dark:text-gray-400">2025.2, Graduate</span>
          </div>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-2">
            Methodological Training of <a href="https://mape.org.br/" class="link" target="_blank" rel="noopener noreferrer">MAPE</a>
          </p>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
            Fundamentals of machine learning, focusing on recognizing, training, interpreting, and evaluating simple predictive models applied to social research.
          </p>
          <div class="mt-3 text-sm">
            <a href="https://github.com/felipelmc/Presentations/tree/main/ML-FMMAPE-2025" class="link" target="_blank" rel="noopener noreferrer">Files →</a>
          </div>
        </div>

        <div class="card">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
            <h3 class="font-semibold text-gray-900 dark:text-white">Deep Learning & Text-as-Data</h3>
            <span class="text-sm text-gray-500 dark:text-gray-400">2025.2, Graduate</span>
          </div>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-2">
            10th Student Week of the Postgraduate Programs of IESP-UERJ
          </p>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
            Fundamentals of deep learning: what it is and how to train a neural network, and text-as-data with deep learning.
          </p>
          <div class="mt-3 text-sm">
            <a href="https://github.com/felipelmc/Presentations/tree/main/Minicurso-DL-Jornada-Discente-IESP-2025" class="link" target="_blank" rel="noopener noreferrer">Files →</a>
          </div>
        </div>
      </div>
    </section>

    <section>
      <h2 class="section-title">Teaching Assistance</h2>

      <div class="space-y-6">
        <div class="card">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
            <h3 class="font-semibold text-gray-900 dark:text-white">Advanced Text-as-Data</h3>
            <span class="text-sm text-gray-500 dark:text-gray-400">2025.1, Graduate</span>
          </div>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-2">
            IESP-UERJ Winter School
          </p>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
            Deep Learning, Transformers, Embeddings, and Large Language Models applied to political science research.
          </p>
          <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
            Instructors: <a href="https://www.venturatiago.com/" class="link" target="_blank" rel="noopener noreferrer">Tiago Ventura</a>, Ph.D., and <a href="https://www.svallejovera.com/" class="link" target="_blank" rel="noopener noreferrer">Sebastián Vallejo Vera</a>, Ph.D.
          </p>
          <div class="mt-3 text-sm">
            <a href="https://tiagoventura.github.io/tad_iesp_workshop/" class="link" target="_blank" rel="noopener noreferrer">Course website →</a>
          </div>
        </div>

        <div class="card">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
            <h3 class="font-semibold text-gray-900 dark:text-white">Quantitative Methods II</h3>
            <span class="text-sm text-gray-500 dark:text-gray-400">2024.2, Undergraduate</span>
          </div>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-2">
            FGV CPDOC
          </p>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
            Exploratory data analysis, basic statistical inference, and regression models.
          </p>
          <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
            Instructor: <a href="https://cpdoc.fgv.br/equipe/jaironicolau" class="link" target="_blank" rel="noopener noreferrer">Jairo Nicolau</a>, Ph.D.
          </p>
        </div>

        <div class="card">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-2">
            <h3 class="font-semibold text-gray-900 dark:text-white">Introduction to R</h3>
            <span class="text-sm text-gray-500 dark:text-gray-400">2020.2, Graduate</span>
          </div>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-2">
            FGV CPDOC
          </p>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
            Introduction to programming for social sciences.
          </p>
          <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
            Instructor: <a href="https://cpdoc.fgv.br/equipe/JimmyMedeiros" class="link" target="_blank" rel="noopener noreferrer">Jimmy Medeiros</a>, Ph.D.
          </p>
        </div>
      </div>
    </section>
  </div>
</Layout>
