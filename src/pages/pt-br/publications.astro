        <div class="pub-entry">
          <p class="text-ink-secondary dark:text-ink-secondary-dark leading-relaxed">
            Preference estimation in the Brazilian Congress.
          </p>
          <div class="mt-3 flex flex-wrap gap-4 text-sm">
            <button data-modal="abstract-dissertation" class="link cursor-pointer bg-transparent border-none p-0 text-ink-muted dark:text-ink-muted-dark">{t('publications.abstract.soon')}</button>
          </div>
        </div>
      </div>
    </section>

