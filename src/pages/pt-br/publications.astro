            <a href="#" class="link text-ink-muted dark:text-ink-muted-dark pointer-events-none">{t('publications.replication.soon')}</a>
            <a href="#" class="link text-ink-muted dark:text-ink-muted-dark pointer-events-none">{t('publications.access.soon')}</a>
