---
import Layout from '../../layouts/Layout.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('pt-br');
---

<Layout title={t('publications.title')} description="Working papers, publicações e ferramentas de código aberto" lang="pt-BR">
